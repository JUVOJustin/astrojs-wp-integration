---
/**
 * Runtime page used to validate live post collection behavior inside Astro SSR.
 */
import { getLiveCollection } from 'astro:content';

const {
  entries = [],
  error,
} = await getLiveCollection('livePosts');
const liveErrorMessage = error?.message ?? '';
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>Live Posts Test</title>
</head>
<body>
  <h1>Live Posts ({entries.length})</h1>
  {liveErrorMessage && <p id="live-loader-error">{liveErrorMessage}</p>}
  <ul>
    {entries.slice(0, 3).map((entry) => (
      <li data-id={entry.id}>{entry.data.title?.rendered ?? entry.id}</li>
    ))}
  </ul>
</body>
</html>
