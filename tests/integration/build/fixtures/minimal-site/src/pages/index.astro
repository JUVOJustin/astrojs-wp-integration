---
/**
 * Minimal index page that renders WordPress content from all collections.
 * Used by the build integration test to verify the full Astro pipeline.
 */
import { getCollection } from 'astro:content';

const posts = await getCollection('posts');
const pages = await getCollection('pages');
const categories = await getCollection('categories');
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <title>WP Integration Build Test</title>
</head>
<body>
  <h1>Build Test</h1>

  <section id="posts">
    <h2>Posts ({posts.length})</h2>
    <ul>
      {posts.slice(0, 3).map((post) => (
        <li data-id={post.id}>{post.data.title?.rendered ?? post.id}</li>
      ))}
    </ul>
  </section>

  <section id="pages">
    <h2>Pages ({pages.length})</h2>
    <ul>
      {pages.map((page) => (
        <li data-id={page.id}>{page.data.title?.rendered ?? page.id}</li>
      ))}
    </ul>
  </section>

  <section id="categories">
    <h2>Categories ({categories.length})</h2>
    <ul>
      {categories.map((cat) => (
        <li data-id={cat.id}>{cat.data.name ?? cat.id}</li>
      ))}
    </ul>
  </section>
</body>
</html>
