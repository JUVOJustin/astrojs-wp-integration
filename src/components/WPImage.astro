---
import { Picture } from 'astro:assets';
import type { WordPressEmbeddedMedia, WordPressMedia } from 'fluent-wp-client';
import {
  type OptimizeMode,
  type ResolveWordPressImageForAstroOptions,
  resolveWordPressImageForAstro,
} from './astro-image';

/** Props for rendering already-loaded WordPress media through Astro. */
interface Props {
  /** Pre-loaded media data from loaders, media collections, or `_embed=true` responses. */
  media: WordPressMedia | WordPressEmbeddedMedia;
  /** WordPress registered image size to render, for example `thumbnail`, `medium`, `large`, or `full`. */
  size?: string;
  /**
   * Optimization mode.
   * - `auto` (default): Optimize at build/prerender. Use WordPress srcset at runtime unless a real image service is configured.
   * - `always` / `true`: Force Astro optimization.
   * - `never` / `false`: Always use WordPress srcset.
   */
  optimize?: OptimizeMode;
  /** Modern source formats generated by Astro when optimization is active. */
  formats?: ('avif' | 'png' | 'webp' | 'jpeg' | 'jpg' | 'svg')[];
  /** Fallback `<img>` format. Defaults to the source URL extension, e.g. `.jpg` -> `jpeg`. */
  fallbackFormat?: 'avif' | 'png' | 'webp' | 'jpeg' | 'jpg' | 'svg';
  /** Quality passed to Astro image services. */
  quality?: number | 'low' | 'mid' | 'high' | 'max';
  /** Responsive widths passed to Astro. Defaults to WordPress media sizes. */
  widths?: number[];
  /** Image crop fit passed to Astro image services. */
  fit?: 'fill' | 'contain' | 'cover' | 'none' | 'scale-down' | (string & {});
  /** Image crop position passed to Astro image services. */
  position?: string;
  /** Accessible alt text. Defaults to WordPress alt text, then media title. */
  alt?: string;
  class?: string;
  loading?: 'lazy' | 'eager';
  decoding?: 'async' | 'auto' | 'sync';
  fetchpriority?: 'high' | 'low' | 'auto';
  width?: number;
  height?: number;
  sizes?: string;
}

const {
  media,
  size,
  optimize,
  formats,
  fallbackFormat,
  quality,
  widths,
  fit,
  position,
  alt,
  class: className = '',
  loading,
  decoding,
  fetchpriority,
  width,
  height,
  sizes,
} = Astro.props;

const imageProps = await resolveWordPressImageForAstro(Astro, media, {
  size,
  optimize,
  formats,
  quality,
  sizes,
  loading,
  decoding,
  fetchpriority,
  alt,
  width,
  height,
  widths,
  fallbackFormat,
} satisfies ResolveWordPressImageForAstroOptions);
---

{
  imageProps.kind === 'picture' ? (
    <picture>
      {imageProps.sources.map((source) => (
        <source 
          type={source.type} 
          srcset={source.srcSet} 
          sizes={source.sizes}
        />
      ))}
      <img
        src={imageProps.img.src}
        srcset={imageProps.img.srcSet}
        sizes={imageProps.img.sizes}
        alt={imageProps.img.alt}
        width={imageProps.img.width}
        height={imageProps.img.height}
        loading={imageProps.img.loading}
        decoding={imageProps.img.decoding}
        fetchpriority={imageProps.img.fetchpriority}
        class={className}
      />
    </picture>
  ) : (
    <img
      src={imageProps.img.src}
      srcset={imageProps.img.srcSet}
      sizes={imageProps.img.sizes}
      alt={imageProps.img.alt}
      width={imageProps.img.width}
      height={imageProps.img.height}
      loading={imageProps.img.loading}
      decoding={imageProps.img.decoding}
      fetchpriority={imageProps.img.fetchpriority}
      class={className}
    />
  )
}
