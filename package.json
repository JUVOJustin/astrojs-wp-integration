{
  "name": "wp-astrojs-integration",
  "version": "0.6.0",
  "description": "Fast and better WordPress integration for Astro.js with live loaders, client API, and Gutenberg block support",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./actions": {
      "types": "./dist/actions/index.d.ts",
      "import": "./dist/actions/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js"
    },
    "./ai-sdk": {
      "types": "./dist/ai-sdk/index.d.ts",
      "import": "./dist/ai-sdk/index.js"
    },
    "./components": {
      "import": "./src/components/index.ts"
    },
    "./components/WPImage.astro": {
      "import": "./src/components/WPImage.astro"
    },
    "./components/WPContent.astro": {
      "import": "./src/components/WPContent.astro"
    }
  },
  "files": [
    "dist",
    "src/components"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build",
    "format": "biome format --write .",
    "format:check": "biome check .",
    "test": "vitest run",
    "test:integration": "vitest run --project integration",
    "test:build": "vitest run --project static-build",
    "test:watch": "vitest --project integration --project static-build",
    "wp:start": "wp-env start",
    "wp:stop": "wp-env stop",
    "wp:clean": "wp-env clean all",
    "wp:status": "wp-env status"
  },
  "keywords": [
    "astro",
    "wordpress",
    "cms",
    "gutenberg",
    "headless",
    "astro-integration",
    "wp-api"
  ],
  "author": "juvojustin",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JUVOJustin/astrojs-wp-integration.git"
  },
  "bugs": {
    "url": "https://github.com/JUVOJustin/astrojs-wp-integration/issues"
  },
  "homepage": "https://github.com/JUVOJustin/astrojs-wp-integration#readme",
  "license": "MIT",
  "dependencies": {
    "fluent-wp-client": "^3.0.0-rc.3"
  },
  "peerDependencies": {
    "ai": ">=5.0.0",
    "astro": "^6.0.0"
  },
  "peerDependenciesMeta": {
    "ai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@astrojs/node": "^10.0.5",
    "@biomejs/biome": "^2.4.12",
    "@wordpress/env": "^11.4.0",
    "ai": "^5.0.179",
    "astro": "^6.1.8",
    "devalue": "^5.6.4",
    "typescript": "^5.7.2",
    "vitest": "^4.0.18"
  }
}
